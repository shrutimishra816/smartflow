# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:smartflow123@localhost:5432/smartflow

# ── Auth ───────────────────────────────────────
SECRET_KEY=smartflow-secret-key-change-in-production

# ── ML Models ─────────────────────────────────
ML_MODELS_PATH=../ml/outputs/models

# ── App ────────────────────────────────────────
DEBUG=True
FRONTEND_URL=http://localhost:3000

# ── Fitbit OAuth ───────────────────────────────
# Register at: https://dev.fitbit.com/apps/new
# Set OAuth 2.0 Redirect URI to: http://localhost:8000/api/watch/fitbit/callback
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:8000/api/watch/fitbit/callback

# ── Google Fit OAuth ───────────────────────────
# Register at: https://console.cloud.google.com
# Enable "Fitness API", create OAuth credentials
# Set redirect URI to: http://localhost:8000/api/watch/googlefit/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/watch/googlefit/callback
